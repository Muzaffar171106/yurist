# Yurist AI monorepo ignores

# Secrets and local runtime data
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
data/*.json
backend/data/*.json

# Node / backend
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Flutter / Dart
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
build/
flutter/build/
flutter/.dart_tool/
flutter/.idea/
flutter/*.iml

# Android generated/local
**/android/.gradle/
**/android/local.properties

# iOS generated/local
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/Flutter/ephemeral/
**/ios/Pods/
**/ios/.symlinks/
**/ios/Runner.xcworkspace/xcuserdata/
**/ios/Runner.xcodeproj/xcuserdata/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
